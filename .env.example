# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/social-experiments

# JWT secret — MUST be changed before deployment.
# Generate a strong secret: openssl rand -hex 64  (produces 64 hex chars = 256 bits)
JWT_SECRET=CHANGE_ME_use_a_strong_random_secret_at_least_64_chars

# Token lifetime (e.g. 1h, 7d)
JWT_EXPIRES_IN=1h

# Server port
PORT=3000
